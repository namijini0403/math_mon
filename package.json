{
  "name": "math-mon",
  "private": true,
  "version": "0.1.0",
  "description": "초등 5학년 수학 듀오링고 스타일 학습 PWA",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client && npm run build -w server",
    "test": "npm run test -w client",
    "preview:problems": "npm run preview:problems -w client",
    "start": "npm run start -w server"
  },
  "engines": {
    "node": ">=20"
  }
}
