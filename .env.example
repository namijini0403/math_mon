# ── DRACONIS 서버 환경변수 (Railway 등) ──────────────────────────────
# 운영 DB (게임 저장·계정) — Supabase 프로젝트 #1 Postgres 연결 문자열
DATABASE_URL=postgresql://user:password@host:5432/postgres

# 분석 DB (가명 이벤트 로그) — Supabase 프로젝트 #2 (Seoul 리전, 별도 프로젝트!)
# 비워두면 /api/events는 검증만 하고 저장하지 않는 no-op 모드로 동작
ANALYTICS_DB_URL=

# JWT 서명 비밀키 — 운영에서는 반드시 길고 무작위한 값으로 설정
# (없으면 부팅마다 랜덤 생성되어 재시작 시 모든 토큰이 무효화됨)
JWT_SECRET=

# 교사 API 키 (반 생성·현황 조회)
TEACHER_KEY=

# 서버 포트 (기본 3000)
# PORT=3000
